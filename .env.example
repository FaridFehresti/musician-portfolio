# Copy to .env and fill in. The .env file is gitignored.
ADMIN_USER=admin
ADMIN_PASS=change-this-now
SESSION_SECRET=replace-with-a-long-random-string
PORT=3001

# Public origin of the deployed site, e.g. https://yourartist.com
# Used to build absolute URLs for share-card (og:image / twitter:image) tags.
# If unset, the server derives it from the incoming request host.
PUBLIC_URL=
